// Prisma schema for Third Eye Worldwide dynamic site.
//
// Branch deploy/vercel-vps targets Postgres because the database
// lives on a VPS reachable from Vercel's serverless functions over
// the public internet — SQLite's single-writer / file-on-disk model
// doesn't fit that topology. The schema is portable; the only diff
// from main is the `provider` line below.
//
// Existing prisma/migrations/* are SQLite-flavoured and won't apply
// against Postgres. The runbook walks through generating a fresh
// initial migration on the VPS DB before switching the app over.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Single-row table holding the full site content document.
// Stored as a JSON string so the CMS can evolve the shape without migrations.
// Each item inside the document carries `visible` (boolean) and `order` (int)
// properties so the CMS can show/hide and reorder without schema changes.
model SiteContent {
  id        Int      @id @default(1)
  data      String   // JSON string
  updatedAt DateTime @updatedAt
}

// Every publish creates a revision. Lets the CMS offer rollback later.
model ContentRevision {
  id        Int      @id @default(autoincrement())
  data      String   // JSON string
  author    String?
  note      String?
  createdAt DateTime @default(now())

  // pruneRevisions() orders by createdAt on every successful publish.
  @@index([createdAt])
}

// Volunteer form submissions — sent from /volunteers form, triaged in /admin.
// `confirmed` flips true after the user clicks the link in the
// confirmation email (MED-8). Admin GET filters to confirmed=true by
// default.
model VolunteerSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  role      String?
  skills    String?
  message   String?
  status    String   @default("new") // new | contacted | onboarded | rejected
  confirmed Boolean  @default(false)
  // Free-form admin notes shown only in the dashboard (CMS_ROADMAP PR #4).
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Admin lists default to confirmed=true ordered by createdAt desc.
  @@index([confirmed, createdAt])
  @@index([status])
  @@index([email])
}

// Donation form submissions — record of intent; payment processing is external.
// `confirmed` flips true after the user clicks the link in the
// confirmation email (MED-8).
model DonationSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  amount    Int      // integer cents (e.g. $49.99 → 4999)
  mode      String   // monthly | once
  currency  String   @default("USD")
  status    String   @default("pending") // pending | succeeded | failed
  note      String?
  // Free-form admin notes shown only in the dashboard (CMS_ROADMAP PR #4).
  adminNote String?
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([confirmed, createdAt])
  @@index([status])
  @@index([email])
}

// Admin users for the /admin CMS dashboard.
//
// `role` is `admin` (full access) or `editor` (content edit only —
// can't manage users or view the audit log). Defaults to `editor`
// for newly created records so a forgotten role flag can't promote
// an invited user to admin by accident; the seed user is forced to
// `admin` explicitly. lastLogin is updated on every successful
// authorize() call.
model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String?
  role         String    @default("editor") // admin | editor
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
}

// Media assets uploaded via the dashboard (CMS_ROADMAP PR #1).
//
// `kind` is one of `image | video | audio | document`. Variant URLs
// (urlThumb, urlMedium) and `blurhash` are populated only when the
// storage adapter ran an image pipeline; they stay null for raw
// uploads, video/audio/document, and the local-disk dev adapter.
//
// `url` is always the canonical full-size URL — relative when stored
// on the same origin, absolute otherwise.
model MediaAsset {
  id         String   @id @default(cuid())
  kind       String   // image | video | audio | document
  filename   String
  mime       String
  bytes      Int
  width      Int?
  height     Int?
  duration   Float?   // audio/video, seconds
  alt        String?
  caption    String?
  url        String
  urlThumb   String?  // ~320w
  urlMedium  String?  // ~1024w
  blurhash   String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
}

// Append-only record of every CMS write. CMS_ROADMAP PR #7. Each
// entry pins WHO did WHAT to WHICH thing, plus an optional
// machine-readable diff so a future "Restore" UI can apply the
// inverse patch.
model AuditLogEntry {
  id        String   @id @default(cuid())
  actor     String   // user email or 'system'
  action    String   // 'cms.publish' | 'cms.media.upload' | 'submission.status_update' | …
  target    String?  // path, slug, or record id
  diff      String?  // JSON-patch (RFC 6902) for content edits
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actor])
}
