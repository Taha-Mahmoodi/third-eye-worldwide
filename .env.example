# Third Eye Worldwide — environment configuration
#
# Copy this file to `.env` (gitignored) and fill in the values.
# Both `npm run dev` and Prisma CLI use --env-file=.env automatically.

# -----------------------------------------------------------------------------
# Site URL — used for canonical links, OpenGraph absolute URLs, sitemap.
# Must be the production domain (no trailing slash). NEXT_PUBLIC_ so it's
# available on the client too.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://www.thirdeyeworldwide.org"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Dev: SQLite file. The seed script creates prisma/dev.db on first run.
DATABASE_URL="file:./dev.db"
# Prod (Postgres example — Neon / Supabase / RDS all work):
# DATABASE_URL="postgresql://user:password@host:5432/teww?sslmode=require"

# -----------------------------------------------------------------------------
# Auth — REQUIRED in production
# -----------------------------------------------------------------------------
# Generate with:   openssl rand -base64 32
# If NODE_ENV === 'production' and this is missing, the app refuses to start.
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# First-run admin account (used by `npm run db:seed`)
# -----------------------------------------------------------------------------
CMS_ADMIN_EMAIL="admin@teww.local"
CMS_ADMIN_PASSWORD="change-me"

# -----------------------------------------------------------------------------
# Optional: scripted-client token for CMS PUT requests.
# Kept alongside session auth so automation (CI, migration scripts) and the
# in-browser dashboard's "publish" prompt can write without a session login.
#
# IMPORTANT: this env var stores the SHA-256 *hash* of the real token, not
# the token itself. The header `x-cms-token` carries the raw token; the server
# hashes it and compares (timing-safe) against this value. Storing only the
# hash means a leaked env file or process listing doesn't grant CMS write
# access on its own — see HIGH-5 in CODEBASE_REVIEW.md.
#
# To generate a fresh token + its hash:
#   TOKEN=$(openssl rand -hex 32)
#   echo "Raw token (give to dashboard / scripts): $TOKEN"
#   echo "CMS_TOKEN env value: $(printf '%s' "$TOKEN" | sha256sum | cut -d' ' -f1)"
#
# Leave blank to disable token-based writes (session auth still works).
# Old plain-text values are refused and logged once at startup.
# -----------------------------------------------------------------------------
# CMS_TOKEN=""

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# pino log level: trace | debug | info | warn | error | fatal | silent
# Defaults to "debug" in development and "info" otherwise.
# LOG_LEVEL="info"
