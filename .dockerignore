# Version control + CI
.git
.github
.gitignore
.gitattributes

# Dependencies (deps stage reinstalls)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local build artefacts (builder stage regenerates)
.next
out
build
dist

# Local env + secrets
.env
.env.*
!.env.example

# Dev DB / generated at runtime
prisma/dev.db
prisma/dev.db-journal
prisma/migrations/dev.db*

# OS / editor
.DS_Store
Thumbs.db
.vscode
.idea
*.swp

# Claude / worktree artefacts
.claude
CLAUDE.md
AGENT.md

# Docs not needed at runtime (but keep DEPLOYMENT for ops visibility)
AUDIT.md

# Test + coverage (no tests yet, but future-proof)
coverage
*.log
.nyc_output
